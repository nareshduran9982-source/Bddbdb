def get_stream_url(url: str, quality: str = '720p') -> dict:
    """
    Extract video information and stream URL from any platform
    Supports 1000+ platforms via yt-dlp
    """
    quality_map = {
        '144': '144', '240': '240', '360': '360', '480': '480',
        '720': '720', '1080': '1080', '1440': '1440', '2160': '2160',
        'best': 'best'
    }
    
    quality_value = quality_map.get(quality, '720')
    
    if quality_value == 'best':
        format_spec = 'bestvideo+bestaudio/best'
    else:
        format_spec = f'bestvideo[height<={quality_value}]+bestaudio/best[height<={quality_value}]'
    
    ydl_opts = {
        'format': format_spec,
        'quiet': True,
        'no_warnings': True,
        'extract_flat': False,
        'ignoreerrors': True,
        'no_check_certificate': True,
        'prefer_insecure': True,
        'user_agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
        'cookiefile': None,
    }
    
    try:
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            info = ydl.extract_info(url, download=False)
            
            if info is None:
                raise Exception("Could not extract video information")
            
            # Get video URL
            video_url = None
            if 'url' in info:
                video_url = info['url']
            elif 'formats' in info and len(info['formats']) > 0:
                # Get highest quality format
                video_url = info['formats'][-1]['url']
            
            if not video_url:
                raise Exception("No stream URL found")
            
            return {
                'url': video_url,
                'title': info.get('title', 'Video'),
                'thumbnail': info.get('thumbnail', None),
                'duration': info.get('duration', 0),
                'view_count': info.get('view_count', 0),
                'uploader': info.get('uploader', 'Unknown'),
                'upload_date': info.get('upload_date', 'Unknown'),
                'description': info.get('description', '')[:200],
            }
    
    except Exception as e:
        logger.error(f"Error extracting video: {str(e)}")
        raise e

def format_duration(seconds: int) -> str:
    """Convert seconds to HH:MM:SS format"""
    if not seconds:
        return "Unknown"
    hours = seconds // 3600
    minutes = (seconds % 3600) // 60
    seconds = seconds % 60
    if hours > 0:
        return f"{hours}h {minutes}m {seconds}s"
    else:
        return f"{minutes}m {seconds}s"

